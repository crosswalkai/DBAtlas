# ── DBA Diagnostic Copilot — Local Development Config ──────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GCP Project (used for Firestore and GCS even locally via ADC)
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket for mock data (create this in your GCP project)
GCS_MOCK_DATA_BUCKET=dbms-copilot-mock-data

# Firebase / Auth
# For local dev, auth is DISABLED by default (USE_AUTH=false).
# Set to true only when you have a Firebase project configured.
USE_AUTH=false
FIREBASE_PROJECT_ID=your-firebase-project-id

# SSE token signing secret (any random string for local dev)
SSE_SECRET_KEY=local-dev-secret-change-in-production

# Mock data mode (true = use GCS JSON files, false = real DBMS)
USE_MOCK_DATA=true

# Checkpoint loop config
MAX_CLAUDE_RETRIES=2
MAX_STEPS_DEFAULT=5

# CORS origins (comma-separated, no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level
LOG_LEVEL=INFO
